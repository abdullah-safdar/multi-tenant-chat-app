NODE_ENV=development
PORT=3002
SERVICE_NAME=chat-service

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:mongo@localhost:27017/chat_db?authSource=admin

# ── Redis (presence, typing indicators) ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=chat-service
KAFKA_GROUP_ID=chat-service-group

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://rabbit:rabbit@localhost:5672

# ── JWT (Socket.IO auth) ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
